<Page
  x:Class="Pratice.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Pratice.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="DashboardPage"
  d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid VerticalAlignment="Top">

        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="50" />

            <RowDefinition Height="*" /><!--로그 로우-->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        
        <ui:Button
            Grid.Row="0"
            Grid.Column="0"
            Command="{Binding ViewModel.DeviceOnCommand, Mode=OneWay}"
            Content="시작"
            Icon="Fluent24"
            IsEnabled="{Binding ViewModel.CanStart}"
         />

        <ui:Button
            Grid.Row="0"
            Grid.Column="1"
            Command="{Binding ViewModel.DeviceOffCommand, Mode=OneWay}"
            Content="정지"
            Icon="Fluent24"
         />
        <ui:Button
            Grid.Row="0"
            Grid.Column="3"
            Command="{Binding ViewModel.EmergencyCommand, Mode=OneWay}"
            Content="비상 정지"
            Icon="Fluent24"
         />
        
        <ui:Button
            Grid.Row="0"
            Grid.Column="4"
            Command="{Binding ViewModel.ResetStatusCommand, Mode=OneWay}"
            Content="리셋"
            Icon="Fluent24"
            IsEnabled="{Binding ViewModel.CanReset}"
         />

        <ui:Button
            Grid.Row="0"
            Grid.Column="5"
            Command="{Binding ViewModel.SaveLogsCommand, Mode=OneWay}"
            Content="로그 저장"
            Icon="Fluent24"
         />


        <StackPanel
    Grid.Row="2"
    Grid.Column="1"
    Orientation="Horizontal"
    VerticalAlignment="Center">

            <Ellipse
        Width="16"
        Height="16"
        Margin="0,0,8,0"
        Fill="{Binding ViewModel.StatusColor}" />

            <TextBlock
        VerticalAlignment="Center"
        FontWeight="Bold"
        Text="{Binding ViewModel.DeviceStatus}" />

        </StackPanel>

        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            VerticalAlignment="center"
            Text="장비 상태 : "            
         />

        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            VerticalAlignment="center"
            Text="현재 온도 : "
         />

        <TextBlock
            Grid.Row="3"
            Grid.Column="1"
            VerticalAlignment="center"
            Text="{Binding ViewModel.Temperature, Mode=OneWay, StringFormat={}{0} ℃}"
         />

        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            VerticalAlignment="center"
            Text="현재 압력 : "            
         />

        <TextBlock
            Grid.Row="4"
            Grid.Column="1"
            VerticalAlignment="center"
            Text="{Binding ViewModel.Pressure, Mode=OneWay}"            
         />


        <GroupBox
    Grid.Row="6"
    Grid.Column="0"
    Grid.ColumnSpan="5"
    Header="로그">

            <DataGrid
        ItemsSource="{Binding ViewModel.Logs}"
        AutoGenerateColumns="False"
        IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn
                Header="시간"
                Binding="{Binding Time, StringFormat={}{0:HH:mm:ss}}" />

                    <DataGridTextColumn
                Header="상태"
                Binding="{Binding Type}" />

                    <DataGridTextColumn
                Header="온도"
                Binding="{Binding Temperature, StringFormat={}{0} ℃}" />

                    <DataGridTextColumn
                Header="압력"
                Binding="{Binding Pressure, StringFormat={}{0} kPa}" />

                    <DataGridTextColumn
                Header="메시지"
                Binding="{Binding Message}" />

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>



    </Grid>
</Page>
