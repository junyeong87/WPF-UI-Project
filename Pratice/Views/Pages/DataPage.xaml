<Page x:Class="Pratice.Views.Pages.DataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pratice.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DataPage">

    <Grid>
        <DataGrid
    ItemsSource="{Binding ViewModel.Logs}"
    AutoGenerateColumns="False"
    IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
            Header="시간"
            Binding="{Binding Time, StringFormat={}{0:HH:mm:ss}}" />

                <DataGridTextColumn
            Header="상태"
            Binding="{Binding Type}" />

                <DataGridTextColumn
            Header="온도"
            Binding="{Binding Temperature, StringFormat={}{0} ℃}" />

                <DataGridTextColumn
            Header="압력"
            Binding="{Binding Pressure, StringFormat={}{0} kPa}" />

                <DataGridTextColumn
            Header="메시지"
            Binding="{Binding Message}" />

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Page>
